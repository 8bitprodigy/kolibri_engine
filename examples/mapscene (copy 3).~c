/*
    mapscene_RenderMap
        Renders wireframe of the MapData. Called once per frame.
        Iterates every compiled brush, accesses its faces through indices,
        and draws each visible face as a wireframe polygon using raylib's
        3D line primitives.
*/
static void
mapscene_RenderMap(Scene *scene, Head *head)
{
    Renderer     *renderer = Engine_getRenderer(Scene_getEngine(scene));
    MapSceneData *sd       = (MapSceneData*)Scene_getData(scene);
    Camera       *camera   = Head_getCamera(head);
    (void)camera;

    if (sd && sd->brushes && sd->all_faces && sd->all_vertices) {
        for (int b = 0; b < sd->brush_count; b++) {
            CompiledBrush *brush = &sd->brushes[b];

            for (int f = 0; f < brush->face_count; f++) {
                CompiledFace *face = &sd->all_faces[brush->face_start + f];

                if (face->vertex_count < 3) continue;
                if (!face->is_visible)      continue;

                Vector3 *face_verts = &sd->all_vertices[face->vertex_start];

                for (int v = 0; v < face->vertex_count; v++) {
                    int     next = (v + 1) % face->vertex_count;
                    Vector3 a    = Vector3Scale(face_verts[v],    MAP_SCALE);
                    Vector3 b    = Vector3Scale(face_verts[next], MAP_SCALE);
                    DrawLine3D(a, b, MAGENTA);
                }
            }
        }
    }

    Entity **entities = Scene_getEntities(scene);
    for (size_t i = 0; i < DynamicArray_length(entities); i++)
        Renderer_submitEntity(renderer, entities[i]);
}


/*
    mapscene_RenderLeakVisualization
        Draws the leak diagnostic overlay when sd->has_leak is true:

          - All brush geometry in MAGENTA wireframe (so you can see the
            geometry even though the BSP is broken).
          - The leak path as RED line segments connecting successive waypoints.
          - A wireframe sphere at the leaking entity's origin.

        This is called from mapscene_RenderBSP when has_leak is set, in place
        of the normal BSP wireframe.

        TODO: once GetLeakInfo() is wired up in build_bsp_from_mapdata and the
        leak_path / leak_entity fields are populated, this will work as-is.
*/
static void
mapscene_RenderLeakVisualization(MapSceneData *sd)
{
    /* Magenta brush wireframe -------------------------------------------- */
    if (sd->brushes && sd->all_faces && sd->all_vertices) {
        for (int b = 0; b < sd->brush_count; b++) {
            CompiledBrush *brush = &sd->brushes[b];
            for (int f = 0; f < brush->face_count; f++) {
                CompiledFace *face = &sd->all_faces[brush->face_start + f];
                if (face->vertex_count < 3 || !face->is_visible) continue;

                Vector3 *verts = &sd->all_vertices[face->vertex_start];
                for (int v = 0; v < face->vertex_count; v++) {
                    int     next = (v + 1) % face->vertex_count;
                    Vector3 a    = Vector3Scale(verts[v],    MAP_SCALE);
                    Vector3 b    = Vector3Scale(verts[next], MAP_SCALE);
                    DrawLine3D(a, b, MAGENTA);
                }
            }
        }
    }

    /* Leak path (RED lines) ---------------------------------------------- */
    if (sd->leak_path && sd->leak_path_count >= 2) {
        for (int i = 0; i < sd->leak_path_count - 1; i++) {
            Vector3 a = Vector3Scale(sd->leak_path[i],     MAP_SCALE);
            Vector3 b = Vector3Scale(sd->leak_path[i + 1], MAP_SCALE);
            DrawLine3D(a, b, RED);
        }
    }

    /* Sphere at the leaking entity's origin (RED) ------------------------ */
    Vector3 sphere_pos = Vector3Scale(sd->leak_entity, MAP_SCALE);
    DrawSphereWires(sphere_pos, 0.5f, 3, 8, RED);
}


/*
    mapscene_RenderBSP
        SceneRenderCallback - called once per frame.

        If a leak was detected: draws the leak visualization overlay.
        Otherwise draws the finished GBSPLib BSP faces in GREEN wireframe,
        with the compiled-brush MAGENTA wireframe as a fallback when the BSP
        tree is not yet available.
*/
static void
mapscene_RenderBSP(Scene *scene, Head *head)
{
    Renderer     *renderer = Engine_getRenderer(Scene_getEngine(scene));
    MapSceneData *sd       = (MapSceneData*)Scene_getData(scene);
    Camera       *camera   = Head_getCamera(head);
    (void)camera;

    if (!sd) goto submit_entities;

    /* Leak overlay takes priority over everything else */
    if (sd->has_leak) {
        mapscene_RenderLeakVisualization(sd);
        goto submit_entities;
    }

    /* BSP face wireframe (GREEN) with frustum culling + VIS */
    if (sd->bsp_built && sd->model && sd->model->RootNode[0])
    {
        Frustum *frustum = Head_getFrustum(head);

        /*
            Find which leaf the camera is currently in, then look up its
            vis row so DrawBSPNode_r can skip leaves the camera can't see.
            Falls back to frustum-only culling if VIS hasn't been run.
        */
        const uint8_t *camera_leaf_vis = NULL;
        if (LeafVisBits && NumVisLeafBytes > 0)
        {
            /* Camera position is in render units; BSP is in map units */
            Vector3 cam_map = Vector3Scale(camera->position, 1.0f / MAP_SCALE);
            GBSP_Node *cam_leaf = FindLeaf(sd->model->RootNode[0], &cam_map);
            if (cam_leaf && cam_leaf->PortalLeafNum >= 0
                         && cam_leaf->PortalLeafNum < NumVisLeafs)
            {
                camera_leaf_vis = &LeafVisBits[cam_leaf->PortalLeafNum
                                               * NumVisLeafBytes];
            }
        }

        DrawBSPNode_r(sd->model->RootNode[0], frustum, camera_leaf_vis);
        goto submit_entities;
    }

    /* Fallback: compiled-brush MAGENTA wireframe (BSP not built yet) */
    if (sd->brushes && sd->all_faces && sd->all_vertices) {
        for (int b = 0; b < sd->brush_count; b++) {
            CompiledBrush *brush = &sd->brushes[b];
            for (int f = 0; f < brush->face_count; f++) {
                CompiledFace *face = &sd->all_faces[brush->face_start + f];
                if (face->vertex_count < 3 || !face->is_visible) continue;
                Vector3 *verts = &sd->all_vertices[face->vertex_start];
                for (int v = 0; v < face->vertex_count; v++) {
                    int     next = (v + 1) % face->vertex_count;
                    Vector3 a    = Vector3Scale(verts[v],    MAP_SCALE);
                    Vector3 b    = Vector3Scale(verts[next], MAP_SCALE);
                    DrawLine3D(a, b, MAGENTA);
                }
            }
        }
    }

submit_entities:
    {
        Entity **entities = Scene_getEntities(scene);
        for (size_t i = 0; i < DynamicArray_length(entities); i++)
            Renderer_submitEntity(renderer, entities[i]);
    }
}


static void
mapscene_Free(Scene *scene)
{
    MapSceneData *sd = (MapSceneData*)Scene_getData(scene);
    if (!sd) return;

    if (sd->bsp_built) {
        FreeAllGBSPData();
        sd->model     = NULL;
        sd->bsp_built = false;
    }

    free(sd->all_vertices); sd->all_vertices = NULL; sd->vertex_count = 0;
    free(sd->all_faces);    sd->all_faces    = NULL; sd->face_count   = 0;
    free(sd->brushes);      sd->brushes      = NULL; sd->brush_count  = 0;

    /* Leak path — allocated by GBSPLib (or NULL if never set) */
    free(sd->leak_path);
    sd->leak_path       = NULL;
    sd->leak_path_count = 0;
    sd->has_leak        = false;

    if (sd->map) {
        FreeMapData(sd->map);
        sd->map = NULL;
    }
}


